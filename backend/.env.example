# App
APP_NAME=Document Verification System
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database (SQLite for dev; switch to PostgreSQL via DATABASE_URL)
DATABASE_URL=sqlite:///./document_verification.db
# DATABASE_URL=postgresql+psycopg2://dvs:dvs@db:5432/dvs

# JWT - generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_A_REAL_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend (used for password reset links + CORS)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=30
PASSWORD_HISTORY_SIZE=5
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
RESET_TOKEN_EXPIRY_MINUTES=15

# OCR
OCR_ENABLED=False
OCR_LANGUAGE=eng

# SMTP (use Mailtrap / Gmail app password / SendGrid for real testing)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@dvs.local
SMTP_FROM_NAME=Document Verification System
SMTP_TLS=True
SMTP_DEV_MODE=True
